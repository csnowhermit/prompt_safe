# AI大模型Prompt安全防护系统 - 环境变量模板

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 安全检查配置
SAFETY_THRESHOLD=0.5
ENABLE_MASK=true
ENABLE_CHECK=true

# 模型配置
SAFETY_MODEL=ynygljj/Unified_Prompt_Guard
MAX_PROMPT_TOKENS=32768

# 超时配置
SAFETY_CHECK_TIMEOUT=3
LLM_PROXY_TIMEOUT=30

# 降级策略 (block|allow) - 模型不可用时的处理方式
FALLBACK_STRATEGY=block

# Redis配置 (可选，用于限流)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0